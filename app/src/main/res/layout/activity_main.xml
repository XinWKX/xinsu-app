<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"

    android:layout_width="match_parent"

    android:layout_height="match_parent"

    android:background="#000000"

    android:padding="16dp">

    <!-- 顶部状态文字 -->

    <TextView
        android:id="@+id/statusText"

        android:layout_width="wrap_content"

        android:layout_height="wrap_content"

        android:text="等待连接设备"

        android:textColor="#00FF66"

        android:textSize="18sp"

        android:textStyle="bold"

        android:layout_centerHorizontal="true"

        android:layout_marginTop="12dp"/>

    <!-- ECG 波形区域 -->

    <com.xinsu.heartrate.EcgView
        android:id="@+id/ecgView"

        android:layout_width="match_parent"

        android:layout_height="260dp"

        android:layout_below="@id/statusText"

        android:layout_marginTop="20dp"

        android:background="#050505"/>

    <!-- BPM 数值 -->

    <TextView
        android:id="@+id/bpmText"

        android:layout_width="wrap_content"

        android:layout_height="wrap_content"

        android:text="72"

        android:textColor="#00FF66"

        android:textSize="72sp"

        android:textStyle="bold"

        android:layout_below="@id/ecgView"

        android:layout_centerHorizontal="true"

        android:layout_marginTop="22dp"/>

    <!-- BPM 标签 -->

    <TextView
        android:id="@+id/bpmLabel"

        android:layout_width="wrap_content"

        android:layout_height="wrap_content"

        android:text="BPM"

        android:textColor="#66FF99"

        android:textSize="20sp"

        android:layout_below="@id/bpmText"

        android:layout_centerHorizontal="true"

        android:layout_marginTop="-6dp"/>

    <!-- 底部按钮区域 -->

    <LinearLayout

        android:id="@+id/buttonLayout"

        android:layout_width="match_parent"

        android:layout_height="wrap_content"

        android:orientation="vertical"

        android:layout_alignParentBottom="true"

        android:layout_marginBottom="18dp">

        <!-- 第一排 -->

        <LinearLayout

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:orientation="horizontal"

            android:layout_marginBottom="12dp">

            <!-- 扫描 -->

            <Button
                android:id="@+id/scanButton"

                android:layout_width="0dp"

                android:layout_height="56dp"

                android:layout_weight="1"

                android:text="扫描设备"

                android:textAllCaps="false"

                android:textColor="#FFFFFF"

                android:textSize="16sp"/>

            <Space
                android:layout_width="12dp"

                android:layout_height="wrap_content"/>

            <!-- 演示 -->

            <Button
                android:id="@+id/demoButton"

                android:layout_width="0dp"

                android:layout_height="56dp"

                android:layout_weight="1"

                android:text="演示模式"

                android:textAllCaps="false"

                android:textColor="#FFFFFF"

                android:textSize="16sp"/>
        </LinearLayout>

        <!-- 第二排 -->

        <LinearLayout

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:orientation="horizontal">

            <!-- 导出 -->

            <Button
                android:id="@+id/exportButton"

                android:layout_width="0dp"

                android:layout_height="56dp"

                android:layout_weight="1"

                android:text="导出日志"

                android:textAllCaps="false"

                android:textColor="#FFFFFF"

                android:textSize="16sp"/>

            <Space
                android:layout_width="12dp"

                android:layout_height="wrap_content"/>

            <!-- 设置 -->

            <Button
                android:id="@+id/settingsButton"

                android:layout_width="0dp"

                android:layout_height="56dp"

                android:layout_weight="1"

                android:text="设置"

                android:textAllCaps="false"

                android:textColor="#FFFFFF"

                android:textSize="16sp"/>
        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
